# Frontend-safe Lovable/Supabase values
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy alias (optional if publishable key is set)
VITE_SUPABASE_ANON_KEY=

# Public URL of Alibaba FC deploy worker (Playwright capture + browser extract)
VITE_API_BASE_URL=
# Server-side capture API override (optional; defaults to VITE_API_BASE_URL)
CAPTURE_API_BASE_URL=

# Backend-only Supabase (server functions, storage uploads)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Backend-only Qwen/DashScope values
DASHSCOPE_API_KEY=
QWEN_WORKSPACE_ID=
QWEN_REGION=ap-southeast-1
QWEN_SCRIPT_MODEL=qwen3.7-max
QWEN_FAST_MODEL=qwen-plus
QWEN_IMAGE_MODEL=qwen-image-2.0
QWEN_IMAGE_SIZE=1664*928
QWEN_VIDEO_MODEL=happyhorse-1.1-t2v
QWEN_IMAGE_TO_VIDEO_MODEL=happyhorse-1.1-i2v
QWEN_VIDEO_FALLBACK_MODEL=wan2.2-t2v-plus
QWEN_IMAGE_TO_VIDEO_FALLBACK_MODEL=wan2.2-i2v-plus
QWEN_TTS_MODEL=qwen3-tts-flash

# Backend-only auth/quota values
DEMO_MODE=true
MAX_SCENES=3
MAX_PARALLEL_VIDEO_JOBS=3
MAX_VIDEO_SECONDS_PER_PROJECT=15
MAX_PROJECTS_PER_USER_PER_DAY=3

# Optional — Lovable AI Gateway for critique, embeddings, and fallbacks
LOVABLE_API_KEY=

# Optional — route Indian-language TTS through Sarvam instead of Qwen
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=meera
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech

# Optional. Keep false for the Qwen Cloud hackathon path.
ALLOW_NON_QWEN_FALLBACKS=false
