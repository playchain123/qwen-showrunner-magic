# Frontend-safe Lovable/Supabase values
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy alias (optional if publishable key is set)
VITE_SUPABASE_ANON_KEY=

# Public URL of Alibaba FC deploy worker (Playwright capture + browser extract)
# See docs/FC_CAPTURE_DEPLOY.md for deploy steps
VITE_API_BASE_URL=
# Server-side capture API override (optional; defaults to VITE_API_BASE_URL)
CAPTURE_API_BASE_URL=

# Backend-only Supabase (server functions, storage uploads)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Backend-only Qwen/DashScope values
DASHSCOPE_API_KEY=
QWEN_WORKSPACE_ID=
QWEN_REGION=ap-southeast-1
QWEN_PLANNER_MODEL=qwen3.7-plus
QWEN_FINAL_MODEL=qwen3.7-max
QWEN_FAST_MODEL=qwen3.6-flash
QWEN_IMAGE_MODEL=qwen-image-2.0
QWEN_IMAGE_PRO_MODEL=qwen-image-2.0-pro
QWEN_IMAGE_SIZE=1664*928
QWEN_VIDEO_PRIMARY_MODEL=happyhorse-1.1-i2v
QWEN_VIDEO_T2V_MODEL=happyhorse-1.1-t2v
QWEN_VIDEO_FALLBACK_MODEL=wan2.2-t2v-plus
QWEN_VIDEO_I2V_FALLBACK_MODEL=wan2.2-i2v-plus
QWEN_TTS_MODEL=qwen3-tts-instruct-flash
QWEN_TRANSCRIBE_MODEL=paraformer-v2

# Backend-only auth/quota values
DEMO_MODE=true
MAX_SCENES=3
DEFAULT_SCENE_DURATION=4
MAX_PARALLEL_VIDEO_JOBS=3
MAX_TOTAL_VIDEO_SECONDS=16
MAX_VIDEO_SECONDS_PER_PROJECT=16
MAX_REGENS_PER_SCENE=1
MAX_PROJECTS_PER_USER_PER_DAY=3

# Optional — route Indian-language TTS through Sarvam instead of Qwen
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=meera
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
